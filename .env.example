BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://api.binance.com

# Private web access. Do not commit real passwords.
APP_USERNAME=gaboLauraV123
APP_PASSWORD=
APP_SESSION_SECRET=

# Keep this false until you have tested everything on paper mode.
BOT_LIVE_TRADING=false
BOT_AUTO_START=false

# Capital and risk limits. The bot only uses free USDT in Spot.
BOT_MAX_CAPITAL_USDT=50
BOT_MAX_TRADE_USDT=6
BOT_MAX_OPEN_POSITIONS=4
BOT_DAILY_PROFIT_TARGET_USDT=10
BOT_DAILY_MAX_LOSS_USDT=2.5
BOT_MIN_NOTIONAL_BUFFER_PCT=12
BOT_MIN_SCORE=82
BOT_HIGH_RISK_MIN_SCORE=90
BOT_SCAN_INTERVAL_MS=60000
BOT_SCAN_UNIVERSE_LIMIT=140
BOT_MIN_QUOTE_VOLUME_USDT=2500000
BOT_MAX_24H_CHANGE_PCT=35

# Default Binance Spot taker fee fallback. The backend tries to query the real rate.
BOT_TAKER_FEE_RATE=0.001

# Strategy exits.
BOT_STOP_LOSS_PCT=1.8
BOT_TAKE_PROFIT_PCT=1.2
BOT_TRAILING_STOP_PCT=0.7

# Dynamic mode scans many Binance USDT spot pairs. High-risk entries use smaller size.
BOT_UNIVERSE_MODE=dynamic
BOT_ALLOW_HIGH_RISK=true
BOT_HIGH_RISK_MAX_TRADE_USDT=6
BOT_MAX_HIGH_RISK_OPEN_POSITIONS=2
BOT_HIGH_RISK_STOP_LOSS_PCT=1.2
BOT_HIGH_RISK_TAKE_PROFIT_PCT=1.8

# Conservative whitelist. In dynamic mode use ALL to scan many USDT pairs.
BOT_ALLOWED_SYMBOLS=ALL
BOT_EXCLUDED_SYMBOLS=
